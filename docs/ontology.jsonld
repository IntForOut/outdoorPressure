}, {
  "@id" : "https://intforout.github.io/outdoorPressure#ComputePedestrianMobilityGraph",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "http://purl.org/www.umr-lastig.fr/geodata#Process" ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "Workflow visant à dériver un graphe représentant de généralisée la mobilité effective de tous les randonneurs sur une zone donnée pendant une période donnée, à partir de traces GPS et de données géographiques de contexte. \nIl est implémenté dans la librairie open source « footprint2graph », .\nDépôt Logiciel : https://github.com/umrlastig/footprint2graph\nNotebooks associés : https://footprint2graph.readthedocs.io/en/latest/examples/index.html#reseaux-de-mobilite-pedestre\nParamètres : https://github.com/umrlastig/footprint2graph/tree/main/data/config*.yml"
  } ]
}, {
  "@id" : "https://intforout.github.io/outdoorPressure#ComputePedestrianMobilityGraph3ZonesBaugesChamonix2020-24",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "http://purl.org/www.umr-lastig.fr/geodata#Process" ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "Mise en oeuvre du technical Process ComputePedestrainMobilityGraph sur trois zones des Bauges et de Chammonix sur la période 2020-24. \nLes paramètres utilisés pour le pipeline sur les différentes zones sont indiquées dans les exemples : https://github.com/umrlastig/footprint2graph/tree/main/data/config*.yml\n\nLes données GNSS utilisées pour construire ce jeu de données ont été produites et délivrées par la plateforme Outdoorvision (service fournissant des traces partagées volontairement par des utilisateurs lors de leurs activités de plein air), plateforme soutenue par le Pôle Ressources National Sports de Nature (PRNSN). Les traces ont été extraites de la plateforme, après nettoyage, filtrage et anonymisation."
  } ],
  "http://www.w3.org/ns/prov#specializationOf" : [ {
    "@id" : "https://intforout.github.io/outdoorPressure#ComputePedestrianMobilityGraph"
  } ]
