}, {
  "@id" : "http://purl.org/www.umr-lastig.fr/geodata#BD_TOPO_V3",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://schema.org/alternateName" : [ {
    "@value" : "BD TOPO® description vectorielle 3D ("
  } ],
  "http://schema.org/creator" : [ {
    "@id" : "http://njh.me/contact.geoservices@ign.fr"
  } ],
  "http://schema.org/dateCreated" : [ {
    "@type" : "http://schema.org/Date",
    "@value" : "2002-12-15"
  } ],
  "http://schema.org/datePublished" : [ {
    "@type" : "http://schema.org/Date",
    "@value" : "2025-06-15"
  } ],
  "http://schema.org/description" : [ {
    "@value" : "La BD TOPO® version 3.5 contient une description vectorielle 3D (structurée en objets) des éléments du territoire et de ses infrastructures, de précision métrique.\n\n\t    Les objets de la BD TOPO® sont structurés en thèmes : \n\t     - l'administratif ; \n\t     - le bâti ; \n\t     - l'hydrographie ; \n\t     - les lieux nommés ; \n\t     - l'occupation du sol ; \n\t     - les services et activités ; \n\t     - le transport ; \n\t     - les zones réglementées. \n\n\t    Le processus de production 3D permet de fournir l'altimétrie des objets, ainsi que la hauteur des bâtiments. \n\n\t    Le relief est décrit sous forme de modèles numériques de terrain (MNT). \n\n\t    Depuis la version 3.0, tous les objets possèdent un identifiant unique et stable dans le temps.\n\n\t    Le produit **BDTOPO® Express** est l’édition hebdomadaire de la BDTOPO® si vous avez besoin de travailler sur de la donnée topographique à haute fréquence (disponible depuis mai 2025). \n\n\t    Le produit **Différentiel BD TOPO®** contient les différences géométriques et sémantiques sur l'ensemble du contenu BD TOPO® entre deux éditions trimestrielles successives BD TOPO®. \n\n\t    Plus précisément, l'édition N du Différentiel BD TOPO® en vigueur contient tout objet de la BD TOPO® dont la date de modification, la date de création ou la date de suppression en base est postérieure à la date de prédiffusion de la précédente édition trimestrielle (N-1), équivalent à une activité de mise à jour par l'IGN d'une durée de 3 mois."
  } ],
  "http://schema.org/encodingFormat" : [ {
    "@value" : "GPKG"
  }, {
    "@value" : "PostGreSQL"
  }, {
    "@value" : "SHP"
  }, {
    "@value" : "TMS"
  }, {
    "@value" : "WFS"
  }, {
    "@value" : "WMS"
  }, {
    "@value" : "WMTS"
  } ],
