  "@id" : "https://intforout.github.io/outdoorPressure#OVRecreationalUserMapService",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "http://www.w3.org/ns/dcat#DataService" ],
  "http://purl.org/dc/terms/publisher" : [ {
