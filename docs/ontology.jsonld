  "@id" : "https://intforout.github.io/outdoorPressure#ResilientRoute",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A resilient itinerary is a route that minimizes its environmental impact, exerting no pressure on wildlife or vegetation."
  }, {
    "@language" : "fr",
    "@value" : "Un itinéraire résilient est un itinéraire qui n exerce pas de pression sur la faune et la flore."
