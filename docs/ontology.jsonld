}, {
  "@id" : "https://intforout.github.io/outdoorPressure#PedestrianMobilityGraph3ZonesBaugesChamonix-2020-24",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "http://www.w3.org/ns/dcat#Dataset" ],
  "http://purl.org/dc/terms/creator" : [ {
    "@id" : "https://orcid.org/0000-0002-0007-5972"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "Jeu qui retrace l’empreinte humaine liée à l’activité de randonnée sous la forme des chemins communément empruntés, sur 3 petites zones de la Réserve nationale de chasse et de faune sauvage (RNCFS) des Bauges et la vallée de Chamonix-Mont Blanc. Les données sont modélisées sous la forme d’un graphe où la géométrie des arcs correspond aux segments de chemin reconstruits à partir des trajectoires. Les grilles de densité caractérisent l'espace suivant le nombre distincts de traces brutes sur des cellules de 2m sur 2m (inférieure au niveau de détail du chemin)\n\nCe jeu de données est construit à partir d'un ensemble de traces observées lors d’activités de plein air, données Outdoorvision, à l’aide d’un workflow dédié implémenté dans la librairie open source « footprint2graph ». \n\nIl est en cours de dépôt : Doi sur zenodo : https://zenodo.org/records/20800149"
  } ],
  "http://purl.org/www.umr-lastig.fr/geodata#represents" : [ {
    "@id" : "https://intforout.github.io/outdoorPressure#HikingInChamonix"
  }, {
    "@id" : "https://intforout.github.io/outdoorPressure#HikingInLesBauges"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#label" : [ {
    "@language" : "fr",
    "@value" : "Réseau des mobilités effectives de randonneurs au Plan de la Limace"
  } ],
  "http://www.w3.org/ns/dcat#distribution" : [ {
    "@id" : "https://intforout.github.io/outdoorPressure#PedestrianMobilityGraph3ZonesBaugesChamonix-2020-24-FTPDistribution"
  } ],
  "http://www.w3.org/ns/prov#wasGeneratedBy" : [ {
    "@id" : "https://intforout.github.io/outdoorPressure#ComputePedestrianMobilityGraph3ZonesBaugesChamonix2020-24"
  } ]
}, {
  "@id" : "https://intforout.github.io/outdoorPressure#PedestrianMobilityGraph3ZonesBaugesChamonix-2020-24-FTPDistribution",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "Le repertoire Reseau_de_mobilite du FTP INTFOROUT est organise en trois sous repertoire correspondant aux 3 zones plus precises couvertes par les donnees. Chaque sous repertoire comporte :  1) un fichier CSV qui contient la géométrie des arcs du graphe ainsi que la topologie avec les identifiants des nœuds entrants et sortants, 2) une grille de densite, aka carte de chaleur, fournie sous un format matriciel (ASC) et 3) la fiche de métadonnées détaillées XML préparée  pour le dépôt sur un entrepôt de recherche ouvert"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/dcat#Distribution"
  } ]
}, {
  "@id" : "https://intforout.github.io/outdoorPressure#PetersEtAlHuntingShapesWilflifeResponse2025GlobalEcology",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "http://purl.org/www.umr-lastig.fr/geodata#ScientificPaper" ],
  "http://purl.org/spar/datacite/relatedIdentifier" : [ {
    "@id" : "https://doi.org/10.1016/j.gecco.2025.e03994"
  } ]
}, {
  "@id" : "https://intforout.github.io/outdoorPressure#PlandEau",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Plan d'eau"
  }, {
    "@language" : "en",
    "@value" : "Water Body"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://intforout.github.io/outdoorPressure#LandEntity"
  } ]
}, {
  "@id" : "https://intforout.github.io/outdoorPressure#Population",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Ensemble of individuals of a species in an land entity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@value" : "http://www.wikidata.org/entity/Q2625603"
  } ]
}, {
  "@id" : "https://intforout.github.io/outdoorPressure#PopulationFootprint",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The footprint of a population is the agregation of the footprint of its individual, understood both as the specific traces they left on the different places they went through and were active in. Traces should be understood as impacts on land entities and are a complex notion to approach. We represent them as land entities themselves for the sake of simplicity and because ecological footprint is often represented that way.\nFor example the footprint of a population of hikers is represented as their agregated trajectory. More concretely, it is a network defined by:\n        • a topology graph G (V, E) : a set of vertices V and a set of edges E, E ⊆ V x V non oriented\n        • a geometry associated with each edge e ∈ E, defined as a sequence of vertices (x,y,z), representing the common path followed by all individual sample trajectories (i.e., aggregated trajectories) of the population."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fr",
    "@value" : "Empreinte d'une population"
  }, {
    "@language" : "en",
    "@value" : "Population Footprint"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://intforout.github.io/outdoorPressure#LandEntity"
  } ]
}, {
  "@id" : "https://intforout.github.io/outdoorPressure#PopulationFootprintFromTracksCollection",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "http://purl.org/www.umr-lastig.fr/geodata#Process" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A modular and iterative aggregation algorithm (MIAA)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Population footprint from a tracks collection"
  } ],
