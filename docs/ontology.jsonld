}, {
  "@id" : "https://intforout.github.io/outdoorPressure#TracesAcquisitionMultiSensorsAndGroundTruthPathInDenseForest",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual", "http://www.w3.org/ns/dcat#Dataset" ],
  "http://purl.org/dc/terms/bibliographicCitation" : [ {
    "@value" : "Raimond, Ana-Maria; Meneroux, Yann; Calloch, Paul; Labbé, Brice; Peseux, Lorine; Tertre, Franck; Clédat, Emmanuel, 2025, \"Multi-sensors and Ground Truth Tracks\", https://doi.org/10.57745/MOUSLS, Recherche Data Gouv, V1"
  } ],
  "http://purl.org/dc/terms/issued" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2025-01-18"
  } ],
  "http://purl.org/dc/terms/language" : [ {
    "@value" : "English"
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@value" : "Licence Ouverte v2.0 (Etalab)"
  } ],
  "http://purl.org/dc/terms/publisher" : [ {
    "@id" : "http://purl.org/www.umr-lastig.fr/geodata#LASTIG"
  } ],
  "http://purl.org/dc/terms/spatial" : [ {
    "@id" : "https://intforout.github.io/outdoorPressure#TestAreaBoisVincennes"
  } ],
  "http://purl.org/spar/datacite/relatedIdentifier" : [ {
    "@value" : "https://doi.org/10.57745/MOUSLS"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The goal of this dataset is to provide in-situ ground truth data to validate an algorithm for fusing GNSS tracks. This dataset is composed of two datasets, each defined by a metadata file. The first was (file tracks_multi_sensors_vincennes_forest.gpkg) contains GNSS tracks and was collected by two researchers using a strict data collection protocol, following the same path at times precisely and at other times with slight deviations. The second (file ground_truth_dense_forest_path.txt) was collected by a group of students and represents ground truth data for the same path in dense forest. English (2025)"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Traces acquisition with Multi-sensors and Ground Truth path in Dense Forest (Vincennes 2025) (MOUSLS)"
  } ],
  "http://www.w3.org/ns/dcat#distribution" : [ {
    "@id" : "https://intforout.github.io/outdoorPressure#GroundTruthPathVincennesForest-csv"
  }, {
    "@id" : "https://intforout.github.io/outdoorPressure#TracksMultiSensorsVincennesForest-gpkg"
  } ],
  "http://www.w3.org/ns/prov#wasAttributedTo" : [ {
    "@id" : "http://purl.org/www.umr-lastig.fr/geodata#amraimond"
  }, {
    "@id" : "http://purl.org/www.umr-lastig.fr/geodata#ymeneroux"
  } ],
  "http://www.w3.org/ns/prov#wasQuotedFrom" : [ {
    "@id" : "https://intforout.github.io/outdoorPressure#SIGSPATIAL24VanDammeEtAl2024"
  } ]
}, {
  "@id" : "https://intforout.github.io/outdoorPressure#Track",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A track is defined as an ordered set of points, each characterized by a position (x, y) and a timestamp (Van Damme et al., 2024)."
  }, {
    "@language" : "fr",
    "@value" : "La trace est définie par un ensemble de points ordonnés, chaque point étant caractérisé par une position (x, y) et un temps (timestamp) (Van Damme et al., 2024). C'est un résultat d'une procédure : soit d'une Observation par un Sensor, capteur gps porté par un objet mobile (Platform), soit d'un retraitement d'une trace brute, soit d'une simulation."
  } ]
}, {
  "@id" : "https://intforout.github.io/outdoorPressure#TracksMultiSensorsVincennesForest-gpkg",
