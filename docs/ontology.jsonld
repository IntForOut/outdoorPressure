    "@value" : "transports"
  }, {
    "@value" : "végétation"
  } ],
  "http://schema.org/name" : [ {
    "@value" : "BD TOPO®"
  } ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.w3.org/ns/dcat#DatasetSeries"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "BD TOPO covers whole French territory, is captured at scale 1/ 10 000, exists since 1990 and aims to provide reference data for mapping and spatial analysis."
  }, {
    "@language" : "fr",
    "@value" : "BD TOPO® V3. La BD TOPO® permet de couvrir de manière cohérente l'ensemble des entités géographiques et administratives du territoire national. La BD TOPO® fournit une information de référence à tous les acteurs de la gestion, de l'aménagement et de l'observation du territoire pour analyser, situer, représenter des données dans leur réalité géographique"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "BD TOPO® V3."
  } ],
  "http://www.w3.org/ns/dcat#language" : [ {
    "@value" : "fr-FR"
  } ]
