###  https://intforout.github.io/outdoorPressure#TracesAcquisitionMultiSensorsAndGroundTruthPathInDenseForest
:TracesAcquisitionMultiSensorsAndGroundTruthPathInDenseForest rdf:type owl:NamedIndividual ,
                                                                       <http://www.w3.org/ns/dcat#Dataset> ;
                                                              <http://www.w3.org/ns/dcat#distribution> :GroundTruthPathVincennesForest-csv ,
                                                                                                       :TracksMultiSensorsVincennesForest-gpkg ;
                                                              <http://www.w3.org/ns/prov#wasAttributedTo> <http://purl.org/www.umr-lastig.fr/geodata#amraimond> ,
                                                                                                          <http://purl.org/www.umr-lastig.fr/geodata#ymeneroux> ;
                                                              <http://www.w3.org/ns/prov#wasQuotedFrom> :SIGSPATIAL24VanDammeEtAl2024 ;
                                                              <http://purl.org/dc/terms/bibliographicCitation> "Raimond, Ana-Maria; Meneroux, Yann; Calloch, Paul; Labbé, Brice; Peseux, Lorine; Tertre, Franck; Clédat, Emmanuel, 2025, \"Multi-sensors and Ground Truth Tracks\", https://doi.org/10.57745/MOUSLS, Recherche Data Gouv, V1" ;
                                                              <http://purl.org/dc/terms/description> "The goal of this dataset is to provide in-situ ground truth data to validate an algorithm for fusing GNSS tracks. This dataset is composed of two datasets, each defined by a metadata file. The first was (file tracks_multi_sensors_vincennes_forest.gpkg) contains GNSS tracks and was collected by two researchers using a strict data collection protocol, following the same path at times precisely and at other times with slight deviations. The second (file ground_truth_dense_forest_path.txt) was collected by a group of students and represents ground truth data for the same path in dense forest. English (2025). Within the research portal distribution, additional files correspond to standard metadata (ISO 19115/19139 XML format, includes station details, measurement uncertainties, and spatial extent), some of which are not inserted in this KG"@en ;
                                                              <http://purl.org/dc/terms/issued> "2025-01-18"^^xsd:date ;
                                                              <http://purl.org/dc/terms/language> "English" ;
                                                              <http://purl.org/dc/terms/license> "Licence Ouverte v2.0 (Etalab)" ;
                                                              <http://purl.org/dc/terms/publisher> <http://purl.org/www.umr-lastig.fr/geodata#LASTIG> ;
                                                              <http://purl.org/dc/terms/spatial> :TestAreaBoisVincennes ;
                                                              <http://purl.org/spar/datacite/relatedIdentifier> "https://doi.org/10.57745/MOUSLS" ;
                                                              rdfs:label "Traces acquisition with Multi-sensors and Ground Truth path in Dense Forest (Vincennes 2025) (MOUSLS)"@en .


