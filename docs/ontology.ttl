#################################################################
#    Object Properties
#################################################################

###  http://purl.org/www.umr-lastig.fr/geodata#has_member
<http://purl.org/www.umr-lastig.fr/geodata#has_member> rdfs:range owl:Thing .


###  https://intforout.github.io/outdoorPressure#affords
:affords rdf:type owl:ObjectProperty ;
         rdfs:domain :LandEntity ;
         rdfs:range :Activity ;
         rdfs:comment "Capacity of a place, or land, to support a given activity, effectively or potentially"@en .


###  https://intforout.github.io/outdoorPressure#hasSTFootprint
:hasSTFootprint rdf:type owl:ObjectProperty ;
                rdfs:domain :Activity ;
                rdfs:range :LandEntity .


###  https://intforout.github.io/outdoorPressure#locatedIn
:locatedIn rdf:type owl:ObjectProperty ;
           rdfs:domain :Population ;
           rdfs:range :LandEntity .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/ns/dcat#Catalog
<http://www.w3.org/ns/dcat#Catalog> rdf:type owl:Class .


###  http://www.w3.org/ns/dcat#CatalogRecord
<http://www.w3.org/ns/dcat#CatalogRecord> rdf:type owl:Class .


###  http://www.w3.org/ns/dcat#DatasetSeries
<http://www.w3.org/ns/dcat#DatasetSeries> rdf:type owl:Class .


###  http://www.w3.org/ns/dcat#Distribution
<http://www.w3.org/ns/dcat#Distribution> rdf:type owl:Class .


###  https://intforout.github.io/outdoorPressure#Activity
:Activity rdf:type owl:Class ;
          rdfs:comment "activity of a living creature, or of a group or of a population, different from prov:Activity in the sense that the purpose of the Activity is not to yield an output."@en ;
          rdfs:label "Activity"@en .


###  https://intforout.github.io/outdoorPressure#AireCampingCar
:AireCampingCar rdf:type owl:Class ;
                rdfs:subClassOf :LandEntity .


###  https://intforout.github.io/outdoorPressure#AireDeDetente
:AireDeDetente rdf:type owl:Class ;
               rdfs:subClassOf :LandEntity .


###  https://intforout.github.io/outdoorPressure#AireProtegee
:AireProtegee rdf:type owl:Class ;
              rdfs:subClassOf :LandEntity ;
              rdfs:comment "Une Aire Protégée est, selon la définition de l'Union internationale pour la conservation de la nature (UICN), « un espace géographique clairement défini, reconnu, consacré et géré, par tout moyen efficace, juridique ou autre, afin d'assurer à long terme la conservation de la nature, des services écosystémiques et des valeurs culturelles qui lui sont associés ». "@fr ;
              rdfs:label "Aire Protégée"@fr ,
                         "Protected Area"@en .


###  https://intforout.github.io/outdoorPressure#AnimalActivity
:AnimalActivity rdf:type owl:Class ;
                rdfs:subClassOf :Activity .


###  https://intforout.github.io/outdoorPressure#AnimalTrack
:AnimalTrack rdf:type owl:Class ;
             rdfs:subClassOf :Track ;
             rdfs:comment "An animal trace is a digital trace corresponding to the path left by an animal tracked using an interoperable connected device and following a defined data collection protocol."@en ,
                          "La trace animale est une trace numérique correspondant à la trace laissée par un animal suivi au moyen d un dispositif connecté interopérable et selon un protocole de collecte défini."@fr .


###  https://intforout.github.io/outdoorPressure#Bois
:Bois rdf:type owl:Class ;
      rdfs:subClassOf :LandEntity .


###  https://intforout.github.io/outdoorPressure#Cycling
:Cycling rdf:type owl:Class ;
         rdfs:subClassOf :HumanActivity .


###  https://intforout.github.io/outdoorPressure#EncounteringZone
:EncounteringZone rdf:type owl:Class ;
                  rdfs:subClassOf :LandEntity ;
                  rdfs:comment "Area where different activities of different creatures take place, which can potentially imply a conflict of land use rather than harmonious land sharing."@en ;
                  rdfs:label "Encountering zone"@en ,
                             "Zone de rencontre"@fr .


###  https://intforout.github.io/outdoorPressure#FastHiking
:FastHiking rdf:type owl:Class ;
            rdfs:subClassOf :Hiking ;
            rdfs:comment """Le Fast hiking est une randonnée rapide qui se pratique à allure soutenue en toute autonomie sur un parcours présentant du dénivelé et/ou des difficultés techniques.
	        Il s’agit d’une discipline plus sportive et plus dynamique que la randonnée classique."""@fr ;
            rdfs:label "Fast hiking"@en ,
                       "Fast hiking"@fr .


###  https://intforout.github.io/outdoorPressure#FilteredTrack
:FilteredTrack rdf:type owl:Class ;
               rdfs:subClassOf :Track ;
               rdfs:comment "Filtered traces represent a set of unstructured traces assumed to follow the network and used for a specific case study. They result from a user-defined filtering process (spatial, temporal, activity type, etc.)."@en ,
                            "Les traces filtrées représentent un ensemble de traces non structurées, présumées suivre le réseau et utilisées pour un cas d étude spécifique. Elles résultent d un processus de filtrage défini par l utilisateur (spatial, temporel, type d activité, etc.)."@fr .


###  https://intforout.github.io/outdoorPressure#Haie
:Haie rdf:type owl:Class ;
      rdfs:subClassOf :LandEntity .


###  https://intforout.github.io/outdoorPressure#Hiking
:Hiking rdf:type owl:Class ;
        rdfs:subClassOf :HumanActivity ;
        rdfs:comment "activité de plein air consistant à se promener de façon ludique ou sportive"@fr ;
        rdfs:label "Hiking"@en ,
                   "Randonnée pédestre"@fr .


###  https://intforout.github.io/outdoorPressure#HumanActivity
:HumanActivity rdf:type owl:Class ;
               rdfs:subClassOf :Activity ;
               rdfs:comment "Human activity taking place outdoor"@en .


###  https://intforout.github.io/outdoorPressure#HumanTrack
:HumanTrack rdf:type owl:Class ;
            rdfs:subClassOf :Track ;
            rdfs:comment "A human trace is a digital trace corresponding to the path left by a person during outdoor activities using interoperable connected devices (GPS watches, apps, smartphones)."@en ,
                         "La trace humaine est une trace numérique correspondant à la trace laissée par un humain lors d une activité de plein air, à l aide de dispositifs connectés interopérables (montres GPS, applications, smartphones)."@fr .


###  https://intforout.github.io/outdoorPressure#LandEntity
:LandEntity rdf:type owl:Class ;
            rdfs:comment "An entity located in land : an area, a land, a parcel, a footprint, an observation."@en .


###  https://intforout.github.io/outdoorPressure#Landmark
:Landmark rdf:type owl:Class ;
          rdfs:subClassOf :LandEntity .


###  https://intforout.github.io/outdoorPressure#MassifMontagneux
:MassifMontagneux rdf:type owl:Class ;
                  rdfs:subClassOf :LandEntity ;
                  rdfs:comment "une montagne ou un massif de manière globale et non un sommet en particulier"@fr ;
                  rdfs:label "Massif montagneux"@fr ,
                             "Mountain Massif"@en .


###  https://intforout.github.io/outdoorPressure#MergedAccurateTrack
:MergedAccurateTrack rdf:type owl:Class ;
                     rdfs:subClassOf :MergedTrack ;
                     rdfs:comment "An accurate merged trace is a merged trace that optimizes a quality criterion Q with respect to the ground truth GT (Van Damme et al., 2024)."@en ,
                                  "La trace fusionnée exacte est une trace fusionnée qui optimise un critère de qualité Q par rapport à la vérité terrain VT (Van Damme et al., 2024)."@fr .


###  https://intforout.github.io/outdoorPressure#MergedTrack
:MergedTrack rdf:type owl:Class ;
             rdfs:subClassOf :Track ;
             rdfs:comment "A merged trace represents the best geometric representation of a set of traces following exactly the same route, defined from an origin point to a destination (Van Damme et al., 2024)."@en ,
                          "La trace fusionnée est la meilleure représentation géométrique d’un ensemble de traces suivant exactement le même trajet, défini d un point d origine à une destination (Van Damme et al., 2024)."@fr .


###  https://intforout.github.io/outdoorPressure#Observation
:Observation rdf:type owl:Class ;
             rdfs:subClassOf :Activity ;
             rdfs:comment "An observation is an act associated with a discrete time instant or period through which a number, term or other symbol is assigned to a phenomenon." ;
             rdfs:label "Observation or SurveyProcess" .


###  https://intforout.github.io/outdoorPressure#PlandEau
:PlandEau rdf:type owl:Class ;
          rdfs:subClassOf :LandEntity ;
          rdfs:label "Plan d'eau"@fr ,
                     "Water Body"@en .


###  https://intforout.github.io/outdoorPressure#Population
:Population rdf:type owl:Class ;
            rdfs:comment "Ensemble of individuals of a species in an land entity."@en ;
            rdfs:seeAlso "http://www.wikidata.org/entity/Q2625603" .


###  https://intforout.github.io/outdoorPressure#PopulationFootprint
:PopulationFootprint rdf:type owl:Class ;
                     rdfs:subClassOf :LandEntity ;
                     rdfs:comment """The footprint of a population is the agregation of the footprint of its individual, understood both as the specific traces they left on the different places they went through and were active in. Traces should be understood as impacts on land entities and are a complex notion to approach. We represent them as land entities themselves for the sake of simplicity and because ecological footprint is often represented that way.
For example the footprint of a population of hikers is represented as their agregated trajectory. More concretely, it is a network defined by:
        • a topology graph G (V, E) : a set of vertices V and a set of edges E, E ⊆ V x V non oriented
        • a geometry associated with each edge e ∈ E, defined as a sequence of vertices (x,y,z), representing the common path followed by all individual sample trajectories (i.e., aggregated trajectories) of the population."""@en ;
                     rdfs:label "Empreinte d'une population"@fr ,
                                "Population Footprint"@en .


###  https://intforout.github.io/outdoorPressure#ResilientRoute
:ResilientRoute rdf:type owl:Class ;
                rdfs:subClassOf :Route ;
                rdfs:comment "A resilient itinerary is a route that minimizes its environmental impact, exerting no pressure on wildlife or vegetation."@en ,
                             "Un itinéraire résilient est un itinéraire qui n exerce pas de pression sur la faune et la flore."@fr .


###  https://intforout.github.io/outdoorPressure#Route
:Route rdf:type owl:Class ;
       rdfs:subClassOf :LandEntity ;
       rdfs:comment "A route represents a path to follow, which may rely (or not) on a physical support such as a road network (Teulade-Denantes et al., 2015). It is characterized by an origin, a destination, a set of waypoints, and a descriptive element."@en ,
                    "Un itinéraire représente un trajet à suivre qui s appuie (ou non) sur un support physique défini par un réseau routier (Teulade-Denantes et al., 2015). Il est caractérisé par une origine, une destination, un ensemble de points de passage et une description."@fr ;
       rdfs:label "Itinéraire"@fr ,
                  "Route"@en .


###  https://intforout.github.io/outdoorPressure#SensitiveArea
:SensitiveArea rdf:type owl:Class ;
               rdfs:subClassOf :LandEntity ;
               rdfs:comment "Zone naturelle sensible où l'environnement est vulnérable à certaines activités humaines. Créé en 2018 et imaginé par la Ligue de Protection des Oiseaux Isère, introduit dans les api des services des parcs régionaux et nationaux. Ce concept permet d'introduire les zones réglementaires et les zones sensibles, de renseigner les zones d’arrêtés de protection du biotope : emplacement, période de régulation, description associée, espèce, typologie de pratique, etc.."@fr ;
               rdfs:label "Sensitive Area"@en ,
                          "Zone sensible"@fr .


###  https://intforout.github.io/outdoorPressure#Sentier
:Sentier rdf:type owl:Class ;
         rdfs:subClassOf :LandEntity .


###  https://intforout.github.io/outdoorPressure#StudyArea
:StudyArea rdf:type owl:Class ;
           rdfs:subClassOf :LandEntity ;
           rdfs:comment "Study area defined within a specific project"@en ;
           rdfs:label "Study area"@en ,
                      "Zone d'étude"@fr .


###  https://intforout.github.io/outdoorPressure#TechnicalDocument
:TechnicalDocument rdf:type owl:Class ;
                   rdfs:subClassOf <http://www.w3.org/ns/dcat#Resource> ;
                   rdf:label "Technical document"@en ;
                   rdfs:comment "A technical document can be for example a data profiling report, a project deliverable, specifications of a data product or of an API"@en .


###  https://intforout.github.io/outdoorPressure#Track
:Track rdf:type owl:Class ;
       rdfs:comment "A track is defined as an ordered set of points, each characterized by a position (x, y) and a timestamp (Van Damme et al., 2024)."@en ,
                    "La trace est définie par un ensemble de points ordonnés, chaque point étant caractérisé par une position (x, y) et un temps (timestamp) (Van Damme et al., 2024). C'est un résultat d'une procédure : soit d'une Observation par un Sensor, capteur gps porté par un objet mobile (Platform), soit d'un retraitement d'une trace brute, soit d'une simulation."@fr .


###  https://intforout.github.io/outdoorPressure#Trajectory
:Trajectory rdf:type owl:Class ;
            rdfs:subClassOf :LandEntity ;
            rdfs:comment "Ligne décrite par un objet en mouvement"@fr ,
                         "Path of a moving object"@en ;
            rdfs:label "Trajectoire"@fr ,
                       "Trajectory"@en .


###  https://intforout.github.io/outdoorPressure#WildlifeQuietArea
:WildlifeQuietArea rdf:type owl:Class ;
                   rdfs:subClassOf :LandEntity ;
                   rdfs:comment "Le terme « zone de quiétude » définit un territoire, volontairement aménagé ou réglementé, qui vise à limiter les dérangements humains sur la faune sauvage. Ces zones offrent un refuge aux espèces sensibles, notamment en période critique comme la reproduction, l’hivernage ou l’élevage des jeunes. En réduisant les perturbations liées aux activités humaines (promenades, sports de nature, circulation…), elles favorisent le maintien de comportements naturels et contribuent à la préservation de la biodiversité. Cependant, des sentiers spécialement balisés sont ouverts au public durant ces période et ont été étudiés pour limiter le dérangement et permettent ainsi de concilier les activités de loisirs et la préservation de la faune."@fr ;
                   rdfs:label "Wildlife Quiet Area"@en ,
                              "Zone de quiétude"@fr .


